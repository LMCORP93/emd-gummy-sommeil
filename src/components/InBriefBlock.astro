---
interface Props { title: string; paragraphs: string[]; assets: string[]; considerations: string[]; product: any; ctaLabel?: string; }
const { title, paragraphs, assets, considerations, product, ctaLabel = 'Voir l’offre' } = Astro.props;
---
<section id="en-bref" class="in-brief-block" aria-labelledby="in-brief-title"><div class="in-brief-top"><div class="in-brief-copy"><span class="in-brief-eyebrow">EN BREF</span><h2 id="in-brief-title">{title}</h2>{paragraphs.map((paragraph)=><p>{paragraph}</p>)}</div><aside class="in-brief-card"><div class="in-brief-logo-wrap"><img src={product.brandLogo} alt={`${product.brand} logo`} loading="lazy" /></div><p class="in-brief-card-label">Notre note sur {product.brand}</p><div class="in-brief-rating"><span>★</span>{Number(product.rating).toFixed(1)}/10</div><p class="in-brief-card-subtitle">Meilleur choix 2026</p><a class="in-brief-cta" href={product.affiliateLink} target="_blank" rel="nofollow sponsored">{ctaLabel}<span>→</span></a></aside></div><div class="in-brief-verdict-label">NOTRE VERDICT</div><div class="in-brief-verdict-grid"><div class="in-brief-verdict-card"><h3><span>✓</span>Les principaux atouts</h3><ul>{assets.map((asset)=><li>{asset}</li>)}</ul></div><div class="in-brief-verdict-card in-brief-verdict-card--warning"><h3><span>⚠</span>Points à considérer</h3><ul>{considerations.map((item)=><li>{item}</li>)}</ul></div></div></section>
<style>.in-brief-block{background:#fbf4e9;border-radius:28px;padding:clamp(1.5rem,3vw,3rem);margin:0 0 2.5rem;color:#141414}.in-brief-top{display:grid;grid-template-columns:minmax(0,1fr) 260px;gap:2rem;align-items:start}.in-brief-eyebrow{display:inline-flex;background:#f97316;color:white;border-radius:999px;padding:.42rem .78rem;font-size:.72rem;font-weight:900;letter-spacing:.08em;margin-bottom:1rem}.in-brief-copy h2{font-size:clamp(2rem,4vw,3.25rem);line-height:1.03;letter-spacing:-.04em;margin:0 0 1rem;color:#111}.in-brief-copy p{font-size:1rem;line-height:1.75;color:#4a4a4a;margin:0 0 1rem}.in-brief-card{background:#fff;border-radius:20px;padding:1.25rem;box-shadow:0 18px 45px rgba(30,20,10,.08);text-align:center}.in-brief-logo-wrap{height:86px;background:#f5f5f5;border-radius:14px;display:flex;align-items:center;justify-content:center;padding:1rem;margin-bottom:1rem}.in-brief-logo-wrap img{max-width:150px;max-height:54px;object-fit:contain}.in-brief-card-label{font-weight:800;line-height:1.25;margin:.25rem 0 .75rem;color:#222}.in-brief-rating{font-size:1.7rem;font-weight:950;color:#111;display:flex;align-items:center;justify-content:center;gap:.35rem}.in-brief-rating span{color:#f97316}.in-brief-card-subtitle{font-size:.9rem;color:#777;margin:.4rem 0 1rem}.in-brief-cta{display:flex;align-items:center;justify-content:center;gap:.5rem;background:#f97316;color:#fff;text-decoration:none;border-radius:999px;padding:.85rem 1rem;font-weight:900}.in-brief-verdict-label{display:inline-flex;background:#111;color:white;padding:.45rem .72rem;border-radius:4px;font-size:.78rem;font-weight:950;letter-spacing:.06em;margin:1.75rem 0 1rem}.in-brief-verdict-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}.in-brief-verdict-card h3{display:flex;align-items:center;gap:.5rem;margin:0 0 .85rem;font-size:1.05rem}.in-brief-verdict-card h3 span{color:#16a34a}.in-brief-verdict-card--warning h3 span{color:#f97316}.in-brief-verdict-card ul{list-style:none;margin:0;padding:0;display:grid;gap:.75rem}.in-brief-verdict-card li{position:relative;padding-left:1.45rem;line-height:1.55;color:#3f3f3f;font-size:.95rem}.in-brief-verdict-card li::before{content:'✓';position:absolute;left:0;color:#16a34a;font-weight:900}.in-brief-verdict-card--warning li::before{content:'×';color:#f97316}@media(max-width:860px){.in-brief-top,.in-brief-verdict-grid{grid-template-columns:1fr}.in-brief-card{max-width:340px}.in-brief-block{border-radius:22px}}</style>
